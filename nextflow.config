manifest {
    name = 'phylloscopus-comparative-ortholog-scaffold'
    author = 'OpenAI Codex'
    homePage = 'https://github.com/example/phylloscopus-ortholog-pipeline'
    description = 'Tier-aware comparative ortholog recovery scaffold for Phylloscopus, with optional ASR and RNA-backed expression modules.'
    version = '0.1.0'
    nextflowVersion = '!>=23.10.0'
}

params {
    species_manifest = "${projectDir}/examples/species_manifest.tsv"
    ortholog_targets = "${projectDir}/examples/ortholog_targets.tsv"
    reference_manifest = "${projectDir}/examples/reference_manifest.tsv"
    run_metadata = ''
    outdir = "${projectDir}/results"
    publish_mode = 'copy'
    execution_mode = 'stub'
    tier_ab_mode = 'scaffold'
    ncbi_api_key = ''
    busco_lineage = ''
    enable_asr = false
    asr_mode = 'scaffold'
    asr_species_tree = ''
    asr_min_taxa = 4
    asr_sequence_type = 'DNA'
    enable_expression = false
    expression_mode = 'scaffold'
    help = false
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
    shell = ['/bin/bash', '-ue']

    withLabel: light {
        cpus = 1
        memory = '1 GB'
        time = '1h'
    }

    withLabel: medium {
        cpus = 4
        memory = '8 GB'
        time = '8h'
    }

    withLabel: heavy {
        cpus = 8
        memory = '32 GB'
        time = '24h'
    }
}

profiles {
    local {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
    }

    conda {
        conda.enabled = true
        process.conda = "${projectDir}/envs/phylloscopus-runtime.yml"
    }
}

timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
}
